  "repository": "https://github.com/ye175888-cell/openclaw-workspace.git",
  "bugs": "https://github.com/ye175888-cell/openclaw-workspace/issues",
  "download_url": "https://github.com/ye175888-cell/openclaw-workspace/releases/download/v1.0.0/context-recall-v1.0.0.tar.gz",
  "size": "31KB",
  "requirements": {
    "node": ">=18.0.0",
    "jq": "optional",
    "cron": "optional"
  },
  "commands": [
    { "name": "recall", "description": "统一入口" },
    { "name": "recall-init", "description": "初始化会话" },
    { "name": "recall-end", "description": "结束会话" },
    { "name": "recall-search", "description": "关键词检索" },
    { "name": "recall-ask", "description": "自然语言查询" },
    { "name": "recall-capture", "description": "捕获信息" },
    { "name": "recall-log", "description": "记录消息" },
    { "name": "recall-tasks", "description": "列出待办" },
    { "name": "recall-extract-tasks", "description": "智能提取待办" },
    { "name": "recall-remind", "description": "任务提醒" },
    { "name": "recall-export", "description": "导出记忆" },
    { "name": "recall-import", "description": "导入记忆" },
    { "name": "recall-tags", "description": "标签管理" },
    { "name": "recall-visualize", "description": "可视化" },
    { "name": "recall-archive", "description": "归档" },
    { "name": "recall-merge", "description": "记忆合并" },
    { "name": "recall-rate", "description": "记忆评分" }
  ],
  "features": [
    "自动会话记录",
    "智能检索（分层策略）",
    "待办自动提取",
    "任务到期提醒",
    "导入导出（JSON/Markdown）",
    "智能标签分类",
    "可视化时间线",
    "自然语言查询",
    "记忆合并去重",
    "用户评分反馈",
    "定时自动归档",
    "AGENTS.md 自动集成"
